[node name="NewAIAssistantTypeWindow" type="Window"]
title = "New AI Assistant Type"
initial_position = 2
size = Vector2i(900, 500)
exclusive = true
script = ExtResource("1_iekrh")

[node name="Background" type="TabContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="MarginContainer" type="MarginContainer" parent="."]
