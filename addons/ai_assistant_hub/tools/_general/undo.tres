[resource]
script = ExtResource("3_n8bsa")
id = "undo"
title = "Undo last tool action"
description = "** Purpose **
Reverts the action performed by a tool, identified by `execution_id`.

** Usage notes **
- `execution_id` must correspond to the tool that performed an undoable action.
- Not all tools perform undoable actions."
