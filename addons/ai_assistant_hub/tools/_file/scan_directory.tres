[sub_resource type="Resource" id="Resource_t85t4"]
script = ExtResource("2_frex3")
type = 3
name = "path"
description = "Path to the target directory."
required = true
string_enum_valid_values = Array[String]([])

[sub_resource type="Resource" id="Resource_m67pl"]
script = ExtResource("2_frex3")
type = 3
name = "file_filter"
description = "Optional filter to limit the file results to those matching this pattern. Supports * and ?. This filter is applied to file names only, it does *NOT* affect directories scanned. If omitted all files are returned."
required = false
string_enum_valid_values = Array[String]([])

[sub_resource type="Resource" id="Resource_66cj8"]
script = ExtResource("2_frex3")
type = 0
name = "max_depth"
description = "Optional number of subdirectory levels to explore. Use 0 to only scan the `path` directory. If omitted it will scan all available levels.."
required = false
string_enum_valid_values = Array[String]([])

[resource]
script = ExtResource("3_7nl0u")
id = "scan_directory"
title = "Scan directories"
description = "**Purpose**
Scan directory `path` to get a list of files and subdirectories.

**Usage notes**
- The root of a Godot project is \"res://\".
- The `path` parameter does not support glob expressions."
category = ExtResource("1_5st00")
parameters = Array[ExtResource("2_frex3")]([SubResource("Resource_t85t4"), SubResource("Resource_m67pl"), SubResource("Resource_66cj8"), ExtResource("5_wo1qm")])
