[ext_resource type="Script" path="res://addons/ai_assistant_hub/tools/ai_tool_parameter.gd" id="1_m618f"]

[resource]
script = ExtResource("1_m618f")
type = 3
name = "rationale"
description = "String with the rationale behind using this tool. It must contain 3 elements: 1. objective = What is the objective of this action? 2. success_next_step = What would be the next action to perform if this tool succeeds? 3. solution_focus = How is this getting you closer to solve the user original request?. Each of these elements must be a concise string of max 2 lines."
required = true
string_enum_valid_values = Array[String]([])
