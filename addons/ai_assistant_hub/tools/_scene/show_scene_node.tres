name = "node_path"
description = "Optional scene‑tree path of the node to select after opening the scene."
required = false
string_enum_valid_values = Array[String]([])

[resource]
script = ExtResource("3_4fvds")
id = "show_scene_node"
title = "Open scene and select node"
description = "**Purpose**  
Open a Godot scene file in the editor and optionally select a node inside that scene.

**Usage**
- If the `scene_path` is provided, the scene will be open in Godot's editor. Leave it blank if you want to stay in the current scene and select some node.
- If the `node_path` is provided, the corresponding node will be selected. If omitted, the scene will simply open.
- You must never omit both `scene_path` and `node_path`.
- Provide both `scene_path` and `node_path` to open the scene and select the node.

**Effect**
The scene will be loaded, the editor will switch to it and the node will be highlighted in the Scene panel."
category = ExtResource("1_68bu8")
parameters = Array[ExtResource("2_yy3x5")]([SubResource("Resource_pffxo"), SubResource("Resource_wgjuk"), ExtResource("4_p2ci0")])
options = Array[ExtResource("1_jhfwf")]([ExtResource("3_pyrsl"), ExtResource("4_2h44v"), ExtResource("5_j4ai1")])
