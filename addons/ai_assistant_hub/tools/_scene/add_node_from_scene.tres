[resource]
script = ExtResource("3_clyxb")
id = "add_node_from_scene"
title = "Add node from scene"
description = "**Purpose**
Add a new node instance to an existing Godot scene by loading a scene file.

**Usage notes**
- The `scene_path` parameter specifies which scene to modify.
- The `source_scene_path` parameter specifies the .tscn file to load and instantiate as a node.
- The `node_name` parameter sets the name for the new node instance.
- The `parent_path` parameter specifies where in the scene hierarchy to add the node. The scene root node path is \".\". For example:
  - Node2D (path \".\")
    - Child1 (path \"Child1\")
      - Grandchild1 (path \"Child1/Grandchild1\")
    - Child2 (path \"Child2\")
- If `parent_path` is omitted, the node will be added to the scene root.

**Example**
scene_path: res://scenes/main_scene.tscn
source_scene_path: res://scenes/enemies/monster.tscn
node_name: Monster01
parent_path: Main/EnemyLayer"
category = ExtResource("1_dainj")
parameters = Array[ExtResource("2_4xwyj")]([SubResource("Resource_cle7k"), SubResource("Resource_yxdym"), SubResource("Resource_lwjn3"), SubResource("Resource_fkj0v"), ExtResource("8_1d3cw")])
options = Array[ExtResource("1_07yyd")]([ExtResource("3_gqyqw"), ExtResource("4_mxkqq"), ExtResource("5_d14rt"), ExtResource("6_3gw6d")])
