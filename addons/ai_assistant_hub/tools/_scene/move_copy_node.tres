[resource]
script = ExtResource("3_65onv")
id = "move_copy_node"
title = "Move or copy node"
description = "**Purpose**
Move a node under a different parent, or make a copy of the node. Optionally giving a new name.

**Usage**
- Provide `scene_path` (required): Path to the scene file containing the node.
- Provide `node_path` (required): Scene-tree path to the target node (e.g., \"Node/SubNode/ChildNode\"). The root node cannot be moved.
- Optionally provide `parent_path`: Scene-tree path to the target parent node. Scene root node is always \".\". If omitted the parent won't change (useful for copying or renaming).
- Provide `is_copy` (required): If true, the node will be copied, if false it will be moved.
- Optionally provide `new_name` if you want to rename the node.

**Effect**
- Opens the specified scene in Godot's editor.
- Moves or copies the node and returns the new node's path relative to the root."
category = ExtResource("1_rp3pw")
parameters = Array[ExtResource("2_4h7yr")]([SubResource("Resource_6c5lj"), SubResource("Resource_tmka8"), SubResource("Resource_ua8h3"), SubResource("Resource_5soxe"), SubResource("Resource_tywry"), ExtResource("8_u6rwn")])
options = Array[ExtResource("1_1jmx0")]([ExtResource("3_5j7vt"), ExtResource("4_8qc1s"), ExtResource("5_o8j5k"), ExtResource("6_w3hst")])
