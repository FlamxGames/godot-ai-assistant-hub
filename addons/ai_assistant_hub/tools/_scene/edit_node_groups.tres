[resource]
script = ExtResource("3_urwc2")
id = "edit_node_groups"
title = "Edit node groups"
description = "**Purpose**
Modify the groups to which a node in a Godot scene belongs.

**Usage**
- Provide `scene_path`: Path to the scene file containing the node.
- Provide `node_path`: Scene-tree path to the target node (e.g., \"Node/SubNode/ChildNode\"). Scene root node is always \".\".
- Provide `group_name`: The target group.
- Provide `action`: \"Add\" to include the node in the group, or \"Remove\" to remove it from the group.

**Effect**
- Opens the specified scene in Godot's editor.
- Alters the groups the node belongs to. Note that the Godot UI will only reflect the change to the user, as a work-around they can move to another scene and come back.
- If needed, you can revert the change using the `undo` tool (if available)."
category = ExtResource("1_4w1va")
parameters = Array[ExtResource("2_yujwi")]([SubResource("Resource_qpkge"), SubResource("Resource_uxmrb"), SubResource("Resource_axh1i"), SubResource("Resource_phjvg"), ExtResource("8_fabhq")])
options = Array[ExtResource("1_gqpul")]([ExtResource("3_6ofpd"), ExtResource("4_tkfhf"), ExtResource("5_r4qnu"), ExtResource("6_wbfwp")])
