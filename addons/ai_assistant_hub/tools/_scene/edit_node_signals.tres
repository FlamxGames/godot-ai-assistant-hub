[resource]
script = ExtResource("3_3vr5q")
id = "edit_node_signals"
title = "Edit node signals"
description = "**Purpose**
Connect or disconnect a signal from one node in a Godot scene to a function on itself or on another node.

**Usage**
- Provide `scene_path`: Path to the scene file containing the nodes
- Provide `emitter_node`: Scene-tree path to the node that emits the signal
- Provide `signal_name`: Name of the signal to connect (e.g., \"pressed\", \"timeout\")
- Optionally provide `target_node`: Scene-tree path to the node that will receive the signal. If omitted the emmiter is used.
- Provide `target_method`: Name of the method to call on the target node.
- Provide `mode`: Use `Connect` or `Disconnect` accordingly.

**Effect**
- Opens the specified scene in Godot's editor.
- Connects the signal and notifies the editor the scene has changed.
- If needed, you can revert the change using the `undo` tool (if available)."
category = ExtResource("1_mua86")
parameters = Array[ExtResource("2_wat7j")]([SubResource("Resource_1xjf7"), SubResource("Resource_nedmk"), SubResource("Resource_dy04k"), SubResource("Resource_bd6lv"), SubResource("Resource_405b0"), SubResource("Resource_hormc"), ExtResource("8_tpmcq")])
options = Array[ExtResource("1_xggig")]([ExtResource("3_660c2"), ExtResource("4_04bs3"), ExtResource("5_f6w4d"), ExtResource("6_2s0wi")])
