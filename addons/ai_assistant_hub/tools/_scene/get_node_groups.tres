[resource]
script = ExtResource("3_iu4fn")
id = "get_node_groups"
title = "Get node groups"
description = "**Purpose**
- Retrieve groups a node belongs to.

**Usage**
- Provide `scene_path` (required): Path to the scene file containing the node.
- Provide `node_path` (required): Scene-tree path to the target node (e.g., \"Node/SubNode/ChildNode\"). Scene root node is always \".\".

**Effect**
- The scene will be opened in the editor.
- Output is the list of groups the node belongs to, or [] if it's not in any groups."
category = ExtResource("1_njdep")
parameters = Array[ExtResource("2_4v4cy")]([SubResource("Resource_n2pgf"), SubResource("Resource_lbhfd"), ExtResource("7_17f7l")])
options = Array[ExtResource("1_5xr7r")]([ExtResource("3_2shed"), ExtResource("4_vqfgo"), ExtResource("5_hg771")])
