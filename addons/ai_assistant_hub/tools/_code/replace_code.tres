required = true
string_enum_valid_values = Array[String]([])

[resource]
script = ExtResource("3_u4jsj")
id = "replace_code"
title = "Replace code"
description = "** Purpose **
Replaces a block of lines in a Godot script specified by `file_path` from `replace_start_line` (inclusive) to `replace_end_line` (inclusive) with the supplied `new_content`.
The file is opened in Godot’s code editor to perform the operation.

** Expected result **
- Returns a trimmed snippet of the file for quick sanity‑check. For example, if you replace lines 100‑140 with 50 new lines, the tool will return context from line 95 to 155, with lines 106‑144 omitted.
- If the returned snippet looks incorrect, you can revert the change using the `undo` tool (if available).

** Usage notes **
- Always inspect the file around the target range before performing the replacement to confirm the current state of the file."
category = ExtResource("1_chhsi")
parameters = Array[ExtResource("2_fyoef")]([SubResource("Resource_rjsy2"), SubResource("Resource_7kl8u"), SubResource("Resource_vxab5"), SubResource("Resource_cvml7"), ExtResource("8_jx8e4")])
options = Array[ExtResource("1_posmw")]([ExtResource("2_yq1ms"), ExtResource("3_x17d6"), ExtResource("4_qjrq1"), ExtResource("5_fewwd"), ExtResource("6_5od60")])
