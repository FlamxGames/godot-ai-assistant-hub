string_enum_valid_values = Array[String]([])

[sub_resource type="Resource" id="Resource_k85n3"]
script = ExtResource("4_usiio")
type = 0
name = "from_line"
description = "Optional 1‑based line number to start reading from. If omitted 1 will be used."
required = false
string_enum_valid_values = Array[String]([])

[sub_resource type="Resource" id="Resource_bl2d8"]
script = ExtResource("4_usiio")
