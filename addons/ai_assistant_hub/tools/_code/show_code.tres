name = "to_line"
description = "Optional 1‑based line number to indicate the last line to read. If omitted the file will be read until the end."
required = false
string_enum_valid_values = Array[String]([])

[resource]
script = ExtResource("5_nd7o8")
id = "show_code"
title = "Open and highlight code"
description = "**Purpose**
Show the user a script file, optionally with a specific range of lines highlighted.

**Effect**
The file will be opened in Godot's code editor. If a range of lines is provided those will be selected and the editor will scroll to that position.

**Usage rules**
1. If you want to show a specific section of the file, do **not** use this tool if you don't know the exact line numbers. Read the file first with another tool if possible.
2. If you omit both `from_line` and `to_line`, the file will open with no selection.
3. If you want to select only one line, use that line number in both `from_line` and `to_line`.

**Response rules**
1. The tool will respond with the highlighted code, do **NOT** include the code in your response. A normal response would be \"I have highlighted the code in the editor for you.\"
2. If the highlighted code is wrong, try reading the file with another tool to identify the correct line numbers."
category = ExtResource("1_dcugv")
parameters = Array[ExtResource("4_usiio")]([SubResource("Resource_6tirh"), SubResource("Resource_k85n3"), SubResource("Resource_bl2d8"), ExtResource("5_ma8bb")])
options = Array[ExtResource("2_863ba")]([ExtResource("3_f6i5o"), ExtResource("4_yt5gj"), ExtResource("5_3k7fa")])
