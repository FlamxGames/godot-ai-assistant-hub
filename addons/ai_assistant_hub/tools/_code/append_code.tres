[sub_resource type="Resource" id="Resource_e3ah8"]
script = ExtResource("7_8lbuq")
type = 3
name = "file_path"
description = "Path to the target file."
required = true
string_enum_valid_values = Array[String]([])

[sub_resource type="Resource" id="Resource_cf5b5"]
script = ExtResource("7_8lbuq")
type = 4
name = "new_content"
description = "Code to insert."
required = true
string_enum_valid_values = Array[String]([])

[sub_resource type="Resource" id="Resource_7rex3"]
script = ExtResource("7_8lbuq")
type = 0
name = "append_line"
description = "1‑based line number where the code will be inserted. If this number is greater than the file's last line, the content will be appended at the end."
required = true
string_enum_valid_values = Array[String]([])

[resource]
script = ExtResource("9_i0dad")
id = "append_code"
title = "Append new code"
description = "** Purpose **
Appends `new_content` in a Godot script specified by `file_path` starting at line number `append_line`.
The file is opened in Godot’s code editor to perform the operation.

** Expected result **
- Returns a trimmed version of the code for you to do a quick sanity-check. For example, if you sent 50 lines of code, inserted at line number 100, you will get lines 95 to 155, with lines 106 to 144 omitted.
- If the returned snippet looks incorrect, you can revert the change using the `undo` tool (if available).

** Usage notes **
- Always read the file around the line you are inserting to confirm the current state of the file.
- To append at the end use a line number greater than the last line."
category = ExtResource("1_f74xr")
parameters = Array[ExtResource("7_8lbuq")]([SubResource("Resource_e3ah8"), SubResource("Resource_cf5b5"), SubResource("Resource_7rex3"), ExtResource("8_xjpvc")])
options = Array[ExtResource("1_fpgpr")]([ExtResource("2_e12ua"), ExtResource("3_dpsk4"), ExtResource("4_14t4k"), ExtResource("5_wdlno"), ExtResource("6_nsbdd")])
