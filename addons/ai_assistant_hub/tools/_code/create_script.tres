[resource]
script = ExtResource("9_qrqyf")
id = "create_script"
title = "Create new script"
description = "**Purpose**
Create a new script file with or without code content.

**Usage notes**
- The `file_path` parameter specifies where the script will be created.
- The `script_content` parameter is optional. If omitted, an empty script is created.
- The file must not exist at the specified path.
- Missing directories in the `file_path` will be created."
category = ExtResource("1_buhs8")
parameters = Array[ExtResource("7_05nai")]([SubResource("Resource_5st71"), SubResource("Resource_t3ur2"), ExtResource("8_mb8b0")])
options = Array[ExtResource("2_1h51g")]([ExtResource("3_6mr48"), ExtResource("4_abm4i"), ExtResource("5_e1eka"), ExtResource("6_imtmf")])
